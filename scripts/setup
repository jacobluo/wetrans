#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if ! command -v swift >/dev/null 2>&1; then
  echo "Swift toolchain not found. Install Xcode or Command Line Tools first." >&2
  exit 1
fi

swift --version
swift package resolve

cat <<'EOF'
Setup complete.

Required integration checks:
- Install libssh2 if it is not available on this Mac.
- Install and start Docker for the default local OpenSSH SFTP E2E fixture.
- Run scripts/verify to execute lint, build, tests, local Docker SFTP E2E, and app smoke.
EOF
