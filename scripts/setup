#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if ! command -v swift >/dev/null 2>&1; then
  echo "Swift toolchain not found. Install Xcode or Command Line Tools first." >&2
  exit 1
fi

swift --version
swift package resolve

cat <<'EOF'
Setup complete.

Optional for real libssh2 probes:
- Install libssh2 if it is not available on this Mac.
- Set WETRANS_RUN_LIBSSH2_REAL_PROBE=1 to run the real runtime probe.
- Set WETRANS_RUN_SFTP_INTEGRATION=1 to run the real SFTP integration test.
EOF
