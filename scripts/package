#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_NAME="wetrans"
BUNDLE_ID="com.jacobluo.wetrans"
MIN_SYSTEM_VERSION="14.0"
CONFIGURATION="${WETRANS_PACKAGE_CONFIGURATION:-release}"
VERIFY_AFTER=0
DIST_DIR="$ROOT/dist"
APP_BUNDLE="$DIST_DIR/$APP_NAME.app"
APP_CONTENTS="$APP_BUNDLE/Contents"
APP_MACOS="$APP_CONTENTS/MacOS"
APP_RESOURCES="$APP_CONTENTS/Resources"
APP_FRAMEWORKS="$APP_CONTENTS/Frameworks"
APP_BINARY="$APP_MACOS/$APP_NAME"
APP_ICON="$ROOT/assets/app-icon/AppIcon.icns"
INFO_PLIST="$APP_CONTENTS/Info.plist"
ZIP_PATH="$DIST_DIR/$APP_NAME.zip"
NOTARY_ZIP_PATH="$DIST_DIR/$APP_NAME-notary.zip"
VERIFY_DIR=""

usage() {
  echo "usage: $0 [--verify]" >&2
}

cleanup() {
  if [[ -n "$VERIFY_DIR" ]]; then
    rm -rf "$VERIFY_DIR"
  fi
}
trap cleanup EXIT

while [[ $# -gt 0 ]]; do
  case "$1" in
    --verify|verify)
      VERIFY_AFTER=1
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
  shift
done

cd "$ROOT"

if [[ "$CONFIGURATION" == "release" ]]; then
  swift build -c release
  BUILD_BINARY="$(swift build -c release --show-bin-path)/$APP_NAME"
else
  swift build
  BUILD_BINARY="$(swift build --show-bin-path)/$APP_NAME"
fi

rm -rf "$APP_BUNDLE" "$ZIP_PATH" "$NOTARY_ZIP_PATH"
mkdir -p "$APP_MACOS" "$APP_RESOURCES" "$APP_FRAMEWORKS"
cp "$BUILD_BINARY" "$APP_BINARY"
chmod +x "$APP_BINARY"

if [[ ! -f "$APP_ICON" ]]; then
  echo "Missing app icon: $APP_ICON" >&2
  exit 1
fi
cp "$APP_ICON" "$APP_RESOURCES/AppIcon.icns"

cat >"$INFO_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>$APP_NAME</string>
  <key>CFBundleIdentifier</key>
  <string>$BUNDLE_ID</string>
  <key>CFBundleName</key>
  <string>$APP_NAME</string>
  <key>CFBundleIconFile</key>
  <string>AppIcon</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSMinimumSystemVersion</key>
  <string>$MIN_SYSTEM_VERSION</string>
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
</dict>
</plist>
PLIST

create_zip() {
  local output_path="$1"
  rm -f "$output_path"
  (
    cd "$DIST_DIR"
    ditto -c -k --keepParent "$APP_NAME.app" "$output_path"
  )
}

first_existing_path() {
  local candidate
  for candidate in "$@"; do
    if [[ -f "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

brew_opt_path() {
  local formula="$1"
  if command -v brew >/dev/null 2>&1; then
    brew --prefix "$formula" 2>/dev/null || true
  fi
}

rewrite_dylib_dependency() {
  local binary_path="$1"
  local dependency_name="$2"
  local replacement="$3"
  local dependency

  while IFS= read -r dependency; do
    install_name_tool -change "$dependency" "$replacement" "$binary_path"
  done < <(
    otool -L "$binary_path" |
      awk -v dependency_name="$dependency_name" '
        $1 ~ dependency_name &&
        $1 !~ /^@/ &&
        $1 !~ /^\/usr\/lib/ &&
        $1 !~ /^\/System\// {
          print $1
        }
      '
  )
}

bundle_native_dependencies() {
  local libssh2_prefix
  local openssl_prefix
  libssh2_prefix="$(brew_opt_path libssh2)"
  openssl_prefix="$(brew_opt_path openssl@3)"

  local libssh2_source
  local libssl_source
  local libcrypto_source

  libssh2_source="$(first_existing_path \
    "${WETRANS_LIBSSH2_DYLIB:-}" \
    "${libssh2_prefix:+$libssh2_prefix/lib/libssh2.dylib}" \
    /opt/homebrew/opt/libssh2/lib/libssh2.dylib \
    /usr/local/opt/libssh2/lib/libssh2.dylib \
    /opt/homebrew/lib/libssh2.dylib \
    /usr/local/lib/libssh2.dylib)" || {
      echo "Missing libssh2. Install it with: brew install libssh2" >&2
      exit 1
    }

  libssl_source="$(first_existing_path \
    "${openssl_prefix:+$openssl_prefix/lib/libssl.3.dylib}" \
    /opt/homebrew/opt/openssl@3/lib/libssl.3.dylib \
    /usr/local/opt/openssl@3/lib/libssl.3.dylib)" || {
      echo "Missing OpenSSL libssl. Install it with: brew install openssl@3" >&2
      exit 1
    }

  libcrypto_source="$(first_existing_path \
    "${openssl_prefix:+$openssl_prefix/lib/libcrypto.3.dylib}" \
    /opt/homebrew/opt/openssl@3/lib/libcrypto.3.dylib \
    /usr/local/opt/openssl@3/lib/libcrypto.3.dylib)" || {
      echo "Missing OpenSSL libcrypto. Install it with: brew install openssl@3" >&2
      exit 1
    }

  cp -f "$libssh2_source" "$APP_FRAMEWORKS/libssh2.dylib"
  cp -f "$libssl_source" "$APP_FRAMEWORKS/libssl.3.dylib"
  cp -f "$libcrypto_source" "$APP_FRAMEWORKS/libcrypto.3.dylib"
  chmod 755 "$APP_FRAMEWORKS/libssh2.dylib" "$APP_FRAMEWORKS/libssl.3.dylib" "$APP_FRAMEWORKS/libcrypto.3.dylib"

  install_name_tool -id "@rpath/libssh2.dylib" "$APP_FRAMEWORKS/libssh2.dylib"
  rewrite_dylib_dependency "$APP_FRAMEWORKS/libssh2.dylib" "libssl\\.3\\.dylib" "@loader_path/libssl.3.dylib"
  rewrite_dylib_dependency "$APP_FRAMEWORKS/libssh2.dylib" "libcrypto\\.3\\.dylib" "@loader_path/libcrypto.3.dylib"

  install_name_tool -id "@rpath/libssl.3.dylib" "$APP_FRAMEWORKS/libssl.3.dylib"
  rewrite_dylib_dependency "$APP_FRAMEWORKS/libssl.3.dylib" "libcrypto\\.3\\.dylib" "@loader_path/libcrypto.3.dylib"

  install_name_tool -id "@rpath/libcrypto.3.dylib" "$APP_FRAMEWORKS/libcrypto.3.dylib"

  echo "Bundled libssh2 runtime dependencies."
}

sign_path() {
  local path="$1"
  if [[ -n "${WETRANS_DEVELOPER_ID_APPLICATION:-}" ]]; then
    codesign \
      --force \
      --timestamp \
      --options runtime \
      --sign "$WETRANS_DEVELOPER_ID_APPLICATION" \
      "$path"
  else
    codesign --force --sign - "$path"
  fi
}

verify_package() {
  [[ -d "$APP_BUNDLE" ]]
  [[ -x "$APP_BINARY" ]]
  [[ -f "$APP_RESOURCES/AppIcon.icns" ]]
  [[ -f "$APP_FRAMEWORKS/libssh2.dylib" ]]
  [[ -f "$APP_FRAMEWORKS/libssl.3.dylib" ]]
  [[ -f "$APP_FRAMEWORKS/libcrypto.3.dylib" ]]
  [[ -f "$ZIP_PATH" ]]

  local plist_executable
  local plist_icon
  plist_executable="$(/usr/libexec/PlistBuddy -c "Print :CFBundleExecutable" "$INFO_PLIST")"
  plist_icon="$(/usr/libexec/PlistBuddy -c "Print :CFBundleIconFile" "$INFO_PLIST")"

  if [[ "$plist_executable" != "$APP_NAME" ]]; then
    echo "Unexpected CFBundleExecutable: $plist_executable" >&2
    exit 1
  fi

  if [[ "$plist_icon" != "AppIcon" ]]; then
    echo "Unexpected CFBundleIconFile: $plist_icon" >&2
    exit 1
  fi

  codesign --verify --deep --strict --verbose=2 "$APP_BUNDLE"

  if otool -L "$APP_FRAMEWORKS"/*.dylib | grep -E "/opt/homebrew|/usr/local|/Cellar"; then
    echo "Bundled dylibs must not depend on Homebrew absolute paths." >&2
    exit 1
  fi

  VERIFY_DIR="$(mktemp -d)"
  ditto -x -k "$ZIP_PATH" "$VERIFY_DIR"
  [[ -x "$VERIFY_DIR/$APP_NAME.app/Contents/MacOS/$APP_NAME" ]]
  [[ -f "$VERIFY_DIR/$APP_NAME.app/Contents/Resources/AppIcon.icns" ]]
  [[ -f "$VERIFY_DIR/$APP_NAME.app/Contents/Frameworks/libssh2.dylib" ]]

  echo "Verified $APP_BUNDLE"
  echo "Verified $ZIP_PATH"
}

bundle_native_dependencies

sign_path "$APP_FRAMEWORKS/libcrypto.3.dylib"
sign_path "$APP_FRAMEWORKS/libssl.3.dylib"
sign_path "$APP_FRAMEWORKS/libssh2.dylib"

if [[ -n "${WETRANS_DEVELOPER_ID_APPLICATION:-}" ]]; then
  sign_path "$APP_BUNDLE"
  codesign --verify --deep --strict --verbose=2 "$APP_BUNDLE"
else
  echo "Skipping Developer ID signing: WETRANS_DEVELOPER_ID_APPLICATION is not set."
  echo "Applying ad-hoc signature for local package validation."
  sign_path "$APP_BUNDLE"
  codesign --verify --deep --strict --verbose=2 "$APP_BUNDLE"
fi

if [[ -n "${WETRANS_NOTARYTOOL_PROFILE:-}" && -n "${WETRANS_DEVELOPER_ID_APPLICATION:-}" ]]; then
  create_zip "$NOTARY_ZIP_PATH"
  xcrun notarytool submit "$NOTARY_ZIP_PATH" \
    --keychain-profile "$WETRANS_NOTARYTOOL_PROFILE" \
    --wait
  xcrun stapler staple "$APP_BUNDLE"
  xcrun stapler validate "$APP_BUNDLE"
  spctl --assess --type execute --verbose=4 "$APP_BUNDLE"
  create_zip "$ZIP_PATH"
  rm -f "$NOTARY_ZIP_PATH"
else
  echo "Skipping notarization: set both WETRANS_DEVELOPER_ID_APPLICATION and WETRANS_NOTARYTOOL_PROFILE."
  create_zip "$ZIP_PATH"
fi

if [[ "$VERIFY_AFTER" == "1" ]]; then
  verify_package
fi

echo "Packaged $APP_BUNDLE"
echo "Created $ZIP_PATH"
