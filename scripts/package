#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_NAME="wetrans"
BUNDLE_ID="com.jacobluo.wetrans"
MIN_SYSTEM_VERSION="14.0"
CONFIGURATION="${WETRANS_PACKAGE_CONFIGURATION:-release}"
DIST_DIR="$ROOT/dist"
APP_BUNDLE="$DIST_DIR/$APP_NAME.app"
APP_CONTENTS="$APP_BUNDLE/Contents"
APP_MACOS="$APP_CONTENTS/MacOS"
APP_RESOURCES="$APP_CONTENTS/Resources"
APP_BINARY="$APP_MACOS/$APP_NAME"
APP_ICON="$ROOT/assets/app-icon/AppIcon.icns"
INFO_PLIST="$APP_CONTENTS/Info.plist"
ZIP_PATH="$DIST_DIR/$APP_NAME.zip"
NOTARY_ZIP_PATH="$DIST_DIR/$APP_NAME-notary.zip"

cd "$ROOT"

if [[ "$CONFIGURATION" == "release" ]]; then
  swift build -c release
  BUILD_BINARY="$(swift build -c release --show-bin-path)/$APP_NAME"
else
  swift build
  BUILD_BINARY="$(swift build --show-bin-path)/$APP_NAME"
fi

rm -rf "$APP_BUNDLE" "$ZIP_PATH" "$NOTARY_ZIP_PATH"
mkdir -p "$APP_MACOS" "$APP_RESOURCES"
cp "$BUILD_BINARY" "$APP_BINARY"
chmod +x "$APP_BINARY"

if [[ ! -f "$APP_ICON" ]]; then
  echo "Missing app icon: $APP_ICON" >&2
  exit 1
fi
cp "$APP_ICON" "$APP_RESOURCES/AppIcon.icns"

cat >"$INFO_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>$APP_NAME</string>
  <key>CFBundleIdentifier</key>
  <string>$BUNDLE_ID</string>
  <key>CFBundleName</key>
  <string>$APP_NAME</string>
  <key>CFBundleIconFile</key>
  <string>AppIcon</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSMinimumSystemVersion</key>
  <string>$MIN_SYSTEM_VERSION</string>
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
</dict>
</plist>
PLIST

create_zip() {
  local output_path="$1"
  rm -f "$output_path"
  (
    cd "$DIST_DIR"
    ditto -c -k --keepParent "$APP_NAME.app" "$output_path"
  )
}

if [[ -n "${WETRANS_DEVELOPER_ID_APPLICATION:-}" ]]; then
  codesign \
    --force \
    --timestamp \
    --options runtime \
    --sign "$WETRANS_DEVELOPER_ID_APPLICATION" \
    "$APP_BUNDLE"
  codesign --verify --deep --strict --verbose=2 "$APP_BUNDLE"
else
  echo "Skipping Developer ID signing: WETRANS_DEVELOPER_ID_APPLICATION is not set."
fi

if [[ -n "${WETRANS_NOTARYTOOL_PROFILE:-}" && -n "${WETRANS_DEVELOPER_ID_APPLICATION:-}" ]]; then
  create_zip "$NOTARY_ZIP_PATH"
  xcrun notarytool submit "$NOTARY_ZIP_PATH" \
    --keychain-profile "$WETRANS_NOTARYTOOL_PROFILE" \
    --wait
  xcrun stapler staple "$APP_BUNDLE"
  xcrun stapler validate "$APP_BUNDLE"
  spctl --assess --type execute --verbose=4 "$APP_BUNDLE"
  create_zip "$ZIP_PATH"
  rm -f "$NOTARY_ZIP_PATH"
else
  echo "Skipping notarization: set both WETRANS_DEVELOPER_ID_APPLICATION and WETRANS_NOTARYTOOL_PROFILE."
  create_zip "$ZIP_PATH"
fi

echo "Packaged $APP_BUNDLE"
echo "Created $ZIP_PATH"
